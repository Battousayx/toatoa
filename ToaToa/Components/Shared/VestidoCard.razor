@inject NavigationManager Nav

<MudCard Elevation="0" Square="true" Class="toatoa-card" Style="cursor:pointer; background:transparent;" @onclick="Abrir">
    <div class="toatoa-img-wrap">
        @if (!string.IsNullOrEmpty(Vestido.ImagemUrl))
        {
            <MudImage Src="@Vestido.ImagemUrl" Alt="@Vestido.Nome" ObjectFit="ObjectFit.Cover"
                      Width="100" Height="380" Class="toatoa-card-img" Style="width:100%; display:block;" />
        }
        else
        {
            <div class="d-flex align-center justify-center" style="height:380px; background:#f5f5f5;">
                <MudIcon Icon="@Icons.Material.Filled.Checkroom" Size="Size.Large" />
            </div>
        }
    </div>
    <MudCardContent Class="px-1 py-3">
        @if (Vestido.Categoria is not null)
        {
            <MudText Typo="Typo.caption" Style="letter-spacing:.1em; text-transform:uppercase; color:#9e9e9e;">@Vestido.Categoria.Nome</MudText>
        }
        <MudText Typo="Typo.subtitle1">@Vestido.Nome</MudText>
        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Vestido.Preco.Brl()</MudText>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public Vestido Vestido { get; set; } = default!;

    private void Abrir() => Nav.NavigateTo($"vestido/{Vestido.Slug}");
}
