@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-3">ToaToa · Admin</MudText>
        <MudSpacer />
        <AuthorizeView>
            <MudText Typo="Typo.body2" Class="mr-4">@context.User.Identity?.Name</MudText>
        </AuthorizeView>
        <form action="Account/Logout" method="post">
            <AntiforgeryToken />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Logout">Sair</MudButton>
        </form>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menu</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="admin" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="admin/categorias" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Category">Categorias</MudNavLink>
            <MudNavLink Href="admin/vestidos" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Checkroom">Vestidos</MudNavLink>
            <MudNavLink Href="admin/pdv" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PointOfSale">PDV</MudNavLink>
            <MudNavLink Href="admin/caixa" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalanceWallet">Caixa</MudNavLink>
            <MudNavLink Href="admin/vendas-do-dia" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ReceiptLong">Vendas do dia</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Storefront">Ver loja</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 pa-6">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro inesperado.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
}
