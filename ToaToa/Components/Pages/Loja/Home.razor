@page "/"
@rendermode InteractiveServer
@inject IVestidoService VestidoService

<PageTitle>ToaToa · Moda feminina em vestidos</PageTitle>

<!-- HERO -->
<div style="position:relative; height:560px; overflow:hidden;">
    <MudImage Src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=1600&q=80"
              Alt="ToaToa" ObjectFit="ObjectFit.Cover" Style="width:100%; height:560px; display:block; filter:brightness(.95);" />
    <div class="toatoa-hero-overlay">
        <MudText Typo="Typo.caption" Class="mb-2" Style="letter-spacing:.3em; text-transform:uppercase;">Nova coleção</MudText>
        <MudText Typo="Typo.h2" Class="brand-title" Style="color:#fff; max-width:680px;">Vestidos para cada ocasião</MudText>
        <MudText Typo="Typo.body1" Class="my-4" Style="max-width:540px;">Elegância atemporal, do casual ao festa.</MudText>
        <MudButton Href="loja" Variant="Variant.Filled" Color="Color.Surface" Size="Size.Large" Class="px-8">Comprar agora</MudButton>
    </div>
</div>

<!-- CATEGORIAS DESTAQUE -->
<MudContainer MaxWidth="MaxWidth.Large" Class="my-12">
    <MudGrid Spacing="3">
        @foreach (var cat in _categorias)
        {
            <MudItem xs="12" sm="4">
                <MudLink Href="@($"loja?cat={cat.Slug}")" Underline="Underline.None" Color="Color.Inherit" Class="toatoa-card" Style="display:block; cursor:pointer;">
                    <div class="toatoa-img-wrap">
                        <MudImage Src="@ImagemCategoria(cat)" Alt="@cat.Nome" ObjectFit="ObjectFit.Cover" Class="toatoa-card-img" Style="width:100%; height:320px; display:block;" />
                    </div>
                    <div class="text-center py-3">
                        <MudText Typo="Typo.h6" Class="brand-title">@cat.Nome</MudText>
                    </div>
                </MudLink>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

<!-- DESTAQUES -->
<MudContainer MaxWidth="MaxWidth.Large" Class="my-12">
    <div class="text-center mb-8">
        <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing:.2em;">Seleção especial</MudText>
        <MudText Typo="Typo.h4" Class="brand-title">Mais desejados</MudText>
    </div>

    @if (_carregando)
    {
        <div class="d-flex justify-center my-8"><MudProgressCircular Indeterminate="true" /></div>
    }
    else
    {
        <MudGrid Spacing="6">
            @foreach (var v in _destaques)
            {
                <MudItem xs="6" sm="4" md="3">
                    <VestidoCard Vestido="v" />
                </MudItem>
            }
        </MudGrid>
        <div class="text-center mt-10">
            <MudButton Href="loja" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Class="px-10">Ver toda a loja</MudButton>
        </div>
    }
</MudContainer>

@code {
    [Inject] private ICategoriaService CategoriaService { get; set; } = default!;

    private bool _carregando = true;
    private List<Vestido> _destaques = new();
    private List<Categoria> _categorias = new();

    protected override async Task OnInitializedAsync()
    {
        _categorias = await CategoriaService.ListarAsync();
        var todos = await VestidoService.ListarAsync(somenteAtivos: true);
        _destaques = todos.Take(8).ToList();
        _carregando = false;
    }

    // Usa a foto principal de um vestido da categoria; senão, um placeholder determinístico.
    private string ImagemCategoria(Categoria cat)
    {
        var doVestido = _destaques.FirstOrDefault(v => v.CategoriaId == cat.Id && !string.IsNullOrEmpty(v.ImagemUrl))?.ImagemUrl;
        return doVestido ?? $"https://picsum.photos/seed/{cat.Slug}/800/600";
    }
}
