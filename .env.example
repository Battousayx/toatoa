# Copie para .env e ajuste (o docker compose lê automaticamente).

# IP público ou domínio da VM (usado para o navegador carregar as imagens do MinIO).
# Ex.: PUBLIC_HOST=159.65.10.20  ou  PUBLIC_HOST=loja.seudominio.com
PUBLIC_HOST=localhost

# Porta pública da loja (mapeada para 8080 do container). 80 = URL sem :porta.
APP_PORT=80

# Credenciais do MinIO (TROQUE em produção!)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
